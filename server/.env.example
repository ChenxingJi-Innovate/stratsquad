# Required
DEEPSEEK_API_KEY=sk-...
SILICONFLOW_API_KEY=sk-...

# Optional (each trend source silently no-ops if its key is absent)
YOUTUBE_API_KEY=AIzaSy...
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stratsquad/0.1 by <your_reddit_username>
STEAM_API_KEY=

# Optional: LangSmith tracing (https://smith.langchain.com)
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=stratsquad

# Model selection
# DEEPSEEK_MODEL=deepseek-v4-flash
# EMBED_MODEL=BAAI/bge-m3
# RERANK_MODEL=BAAI/bge-reranker-v2-m3

# CORS (comma-separated origins for the frontend)
# CORS_ORIGINS=https://stratsquad.vercel.app,http://localhost:3002
