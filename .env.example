# Copy this to .env.local and fill in real values. .env.local is gitignored.

# Required: DeepSeek key (used by all 7 agents).
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: model override. Default = deepseek-v4-flash.
# DEEPSEEK_MODEL=deepseek-v4
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: SiliconFlow key (enables RAG over corpus/). Without it, the trend agent
# falls back to parametric knowledge and the UI's RAG panel stays empty.
# Get a key at https://cloud.siliconflow.cn — free tier covers this demo easily.
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: embedding model override. Default = BAAI/bge-m3 (1024-d).
# EMBED_MODEL=BAAI/bge-large-zh-v1.5
